---
import type { CollectionEntry } from 'astro:content';
import Icon from './Icon.astro';

interface Props {
  project: CollectionEntry<'projects'>;
}
const { project } = Astro.props;
const { title, blurb, status, tags, href, featured, year } = project.data;

const statusMeta: Record<string, { label: string; cls: string }> = {
  live: { label: 'Live', cls: 'badge--live' },
  'coming-soon': { label: 'Coming soon', cls: 'badge--soon' },
  'in-progress': { label: 'In progress', cls: 'badge--progress' },
  planned: { label: 'Planned', cls: 'badge--planned' },
};
const s = statusMeta[status] ?? statusMeta.planned;

const Tag = href ? 'a' : 'article';
const linkAttrs = href ? { href } : {};
---

<Tag class:list={['card', { 'card--featured': featured, 'card--link': !!href }]} {...linkAttrs}>
  <div class="card__top">
    <span class:list={['badge', s.cls]}>{s.label}</span>
    {year && <span class="card__year">{year}</span>}
  </div>

  <h3 class="card__title">{title}</h3>
  <p class="card__blurb">{blurb}</p>

  {
    tags.length > 0 && (
      <ul class="card__tags">
        {tags.map((t) => (
          <li>{t}</li>
        ))}
      </ul>
    )
  }

  {
    href && (
      <span class="card__cta">
        {featured ? 'Open the live demo' : 'View project'}
        <Icon name="arrow" size={18} />
      </span>
    )
  }
</Tag>

<style>
  .card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    height: 100%;
    padding: var(--space-5);
    background: var(--paper);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    transition:
      transform var(--dur) var(--ease),
      box-shadow var(--dur) var(--ease),
      border-color var(--dur) var(--ease);
  }
  .card--link {
    color: inherit;
  }
  .card--link:hover {
    text-decoration: none;
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--border-strong);
  }
  .card--featured {
    border-color: color-mix(in srgb, var(--accent) 35%, var(--border));
    background: linear-gradient(180deg, var(--accent-tint) 0%, var(--paper) 38%);
  }

  .card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }
  .card__year {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--ink-faint);
  }
  .card__title {
    font-size: var(--step-2);
  }
  .card__blurb {
    color: var(--ink-soft);
    font-size: var(--step-0);
  }
  .card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    padding: 0;
    margin-top: auto;
  }
  .card__tags li {
    font-size: 0.74rem;
    color: var(--ink-soft);
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.18rem 0.6rem;
  }
  .card__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: var(--space-2);
    color: var(--accent);
    font-weight: 500;
    font-size: var(--step-0);
  }
  .card__cta :global(svg) {
    transition: transform var(--dur) var(--ease);
  }
  .card--link:hover .card__cta {
    color: var(--accent-strong);
  }
  .card--link:hover .card__cta :global(svg) {
    transform: translateX(4px);
  }
</style>
