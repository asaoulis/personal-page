---
import type { CollectionEntry } from 'astro:content';
import Icon from './Icon.astro';

interface Props {
  project: CollectionEntry<'projects'>;
}
const { project } = Astro.props;
const { title, blurb, status, area, metric, figure, href } = project.data;

const statusMeta: Record<string, { label: string; cls: string }> = {
  live: { label: 'Live', cls: 'badge--live' },
  'coming-soon': { label: 'Coming soon', cls: 'badge--soon' },
  'in-progress': { label: 'Research', cls: 'badge--progress' },
  planned: { label: 'Planned', cls: 'badge--planned' },
};
const s = statusMeta[status] ?? statusMeta.planned;

const Tag = href ? 'a' : 'article';
const linkAttrs = href ? { href } : {};
---

<Tag class:list={['tile', { 'tile--link': !!href }]} data-area={area} {...linkAttrs}>
  <div class="tile__media">
    {
      figure ? (
        <img class="tile__img" src={figure} alt="" loading="lazy" decoding="async" />
      ) : (
        <div class="tile__img tile__img--ph" aria-hidden="true" />
      )
    }
    <span class:list={['badge', s.cls, 'tile__badge']}>{s.label}</span>
  </div>

  <div class="tile__body">
    <h3 class="tile__title">{title}</h3>
    <p class="tile__blurb">{blurb}</p>

    <div class="tile__foot">
      {
        metric && (
          <span class="chip">
            <b>{metric.value}</b> {metric.label}
          </span>
        )
      }
      {
        href && (
          <span class="tile__cta">
            {status === 'live' ? 'Open the monitor' : 'Read more'}
            <Icon name="arrow" size={16} />
          </span>
        )
      }
    </div>
  </div>
</Tag>

<style>
  .tile {
    /* per-area accent, defaulting to teal */
    --tile-accent: var(--accent);
    display: flex;
    flex-direction: column;
    height: 100%;
    background: var(--paper);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition:
      transform var(--dur) var(--ease),
      box-shadow var(--dur) var(--ease),
      border-color var(--dur) var(--ease);
  }
  .tile[data-area='cosmology'] {
    --tile-accent: #6a58c8;
  }
  .tile[data-area='climate'] {
    --tile-accent: var(--amber-strong);
  }
  .tile[data-area='ocean'] {
    --tile-accent: #1f7fae;
  }
  .tile[data-area='timeseries'] {
    --tile-accent: var(--live);
  }
  .tile--link {
    color: inherit;
  }
  .tile--link:hover {
    text-decoration: none;
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: color-mix(in srgb, var(--tile-accent) 40%, var(--border));
  }

  .tile__media {
    position: relative;
    aspect-ratio: 16 / 10;
    /* Solid white: the paper figures are transparent PNGs and need a plain
       print-like backdrop, not the navy band. */
    background: #fff;
    border-bottom: 1px solid var(--border);
  }
  .tile__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s var(--ease);
  }
  .tile__img--ph {
    background:
      radial-gradient(
        120% 120% at 15% 0%,
        color-mix(in srgb, var(--tile-accent) 45%, transparent),
        transparent 55%
      ),
      linear-gradient(140deg, var(--navy), var(--navy-2));
  }
  .tile--link:hover .tile__img {
    transform: scale(1.03);
  }
  .tile__badge {
    position: absolute;
    top: var(--space-3);
    left: var(--space-3);
    backdrop-filter: blur(6px);
  }

  .tile__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-4) var(--space-5) var(--space-5);
    flex: 1;
  }
  .tile__title {
    font-size: var(--step-1);
    line-height: 1.15;
  }
  .tile__blurb {
    color: var(--ink-soft);
    font-size: var(--step-0);
  }
  .tile__foot {
    margin-top: auto;
    padding-top: var(--space-3);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }
  .chip {
    font-size: var(--step--1);
    color: var(--ink-soft);
    background: color-mix(in srgb, var(--tile-accent) 8%, var(--bg-subtle));
    border: 1px solid color-mix(in srgb, var(--tile-accent) 22%, var(--border));
    border-radius: 999px;
    padding: 0.2rem 0.6rem;
  }
  .chip b {
    font-family: var(--font-mono);
    color: var(--tile-accent);
    font-weight: 600;
  }
  .tile__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--tile-accent);
    font-weight: 500;
    font-size: var(--step--1);
    white-space: nowrap;
  }
  .tile__cta :global(svg) {
    transition: transform var(--dur) var(--ease);
  }
  .tile--link:hover .tile__cta :global(svg) {
    transform: translateX(3px);
  }
</style>
