---
interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
}
const { eyebrow, title, lead } = Astro.props;
---

<header class="page-header section--tight">
  <div class="container">
    {eyebrow && <p class="eyebrow reveal">{eyebrow}</p>}
    <h1 class="reveal" data-delay="60ms">{title}</h1>
    {
      lead && (
        <p class="lead page-header__lead reveal" data-delay="120ms">
          {lead}
        </p>
      )
    }
  </div>
</header>

<style>
  .page-header {
    border-bottom: 1px solid var(--border);
  }
  .page-header h1 {
    margin-top: var(--space-2);
  }
  .page-header__lead {
    margin-top: var(--space-4);
    max-width: var(--measure);
  }
</style>
