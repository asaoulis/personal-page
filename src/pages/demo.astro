---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import DemoViewer from '../components/demo/DemoViewer.tsx';

const pipeline = [
  {
    n: '01',
    t: 'Monitor',
    d: 'A scheduled worker watches two public feeds: USGS for new earthquakes (within minutes) and the NIED F-net catalogue for the official reference solutions. Events outside the model’s training region are skipped.',
  },
  {
    n: '02',
    t: 'Infer',
    d: 'For each event, the worker downloads the waveforms and the neural network ingests them, producing the full range of plausible source mechanisms in seconds, on an ordinary CPU.',
  },
  {
    n: '03',
    t: 'Compare',
    d: 'Each marker on the map above is a recent earthquake. Select one to see the model’s inferred fault mechanism alongside the official F-net catalogue solution.',
  },
  {
    n: '04',
    t: 'Explore',
    d: 'Drag the time slider to move through the past months of activity and browse every event the monitor has characterised.',
  },
];
---

<BaseLayout
  title="Live earthquake monitor: Japan"
  description="A live earthquake monitor for Japan: deep-learning models infer each earthquake’s faulting orientation and type from its seismic waveforms, with calibrated uncertainties."
>
  <PageHeader
    eyebrow="Live"
    title="Live earthquake monitor: Japan"
    lead="When an earthquake happens in Japan, this monitor picks up the seismic recordings and a neural network characterises the earthquake: the orientation of the fault, the type of fault. Select a marker to compare the model with the official catalogue solution, and use the slider to move through the month."
  />

  <div class="container container--wide">
    <DemoViewer client:only="react">
      <div slot="fallback" class="demo-fallback">Loading interactive map…</div>
    </DemoViewer>
  </div>

  <section class="section how">
    <div class="container">
      <header class="section-head reveal">
        <p class="eyebrow">What is this?</p>
        <h2>Real-time earthquake characterisation</h2>
        <p class="lead">
          Each seismometer records the ground shaking as a long, noisy signal. A deep neural network
          (a CNN) reads each station’s recording, and a transformer combines the resulting
          embeddings across the whole network into a compact summary. From that summary, the model
          predicts the earthquake’s faulting orientation and type probabilistically.
        </p>
        <p class="lead">
          Our contribution is a holistic approach to uncertainty quantification. The model is
          trained on hundreds of thousands of simulated earthquakes that include the things we
          genuinely do not know: exactly where the source was, and what the Earth’s interior looks
          like along the way. Having seen those effects in training, it gives more accurate
          estimates of the earthquake itself, and it is honest about what the data cannot pin down.
        </p>
      </header>

      <ol class="pipeline">
        {
          pipeline.map((s, i) => (
            <li class="pipeline__step reveal" data-delay={`${i * 80}ms`}>
              <span class="pipeline__n">{s.n}</span>
              <h3 class="pipeline__t">{s.t}</h3>
              <p class="pipeline__d">{s.d}</p>
            </li>
          ))
        }
      </ol>

      <div class="how__note reveal">
        <p>
          The plots and conventions come from the same seismology codebase as my published
          inversions. The page simply serves an operationalised version of our approach.
        </p>
      </div>

      <aside class="disclaimer reveal" aria-label="Disclaimer and data sources">
        <h2 class="disclaimer__head">Disclaimer</h2>
        <p>
          This monitor runs automatically. Events and solutions are not manually inspected, and
          occasional poor solutions are expected, for example when data are extremely poor quality.
          Do not treat the results as an earthquake catalogue; for authoritative solutions, use the
          agency catalogues below.
        </p>
        <p class="disclaimer__sources">
          Data sources: waveforms and reference moment-tensor solutions from{' '}
          <a href="https://www.fnet.bosai.go.jp/">NIED F-net</a> (National Research Institute for Earth
          Science and Disaster Resilience, Japan); event discovery from the{' '}
          <a href="https://earthquake.usgs.gov/earthquakes/feed/">USGS earthquake feed</a>. The
          model is trained on waveforms simulated from 1-D Earth models with{' '}
          <a href="https://github.com/krischer/instaseis">Instaseis</a>/AxiSEM.
        </p>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .demo-fallback {
    min-height: 540px;
    display: grid;
    place-items: center;
    margin-block: var(--space-5);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--bg-subtle);
    color: var(--ink-faint);
    font-family: var(--font-mono);
    font-size: var(--step--1);
  }

  .how {
    border-top: 1px solid var(--border);
    background: var(--bg-subtle);
  }
  .section-head {
    max-width: var(--measure);
    margin-bottom: var(--space-6);
  }
  .section-head h2 {
    margin-top: var(--space-2);
  }
  .section-head .lead {
    margin-top: var(--space-3);
  }

  .pipeline {
    list-style: none;
    padding: 0;
    display: grid;
    gap: var(--space-4);
    grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
  }
  .pipeline__step {
    padding: var(--space-5);
    background: var(--paper);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }
  .pipeline__n {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--accent);
  }
  .pipeline__t {
    font-size: var(--step-1);
    margin: var(--space-2) 0;
  }
  .pipeline__d {
    color: var(--ink-soft);
    font-size: var(--step-0);
  }

  .how__note {
    max-width: var(--measure);
    margin-top: var(--space-6);
    display: grid;
    gap: var(--space-3);
  }

  .disclaimer {
    max-width: var(--measure);
    margin-top: var(--space-7);
    padding: var(--space-5);
    border: 1px solid var(--border-strong, var(--border));
    border-radius: var(--radius-lg);
    background: var(--paper);
    display: grid;
    gap: var(--space-3);
  }
  .disclaimer__head {
    font-size: var(--step-1);
  }
  .disclaimer p {
    color: var(--ink-soft);
    font-size: var(--step-0);
  }
  .disclaimer__sources {
    font-size: var(--step--1);
  }
</style>
