---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import DemoViewer from '../components/demo/DemoViewer.tsx';

const pipeline = [
  {
    n: '01',
    t: 'Monitor',
    d: 'A scheduled worker polls two feeds: USGS origins for near-live discovery (minutes after an earthquake) and the NIED F-net moment-tensor catalogue for the authoritative reference solutions. Events outside the model’s training region or deeper than 80 km are filtered out.',
  },
  {
    n: '02',
    t: 'Infer',
    d: 'It fetches waveforms and runs the trained neural posterior estimator on CPU, producing a full moment-tensor posterior in seconds.',
  },
  {
    n: '03',
    t: 'Publish',
    d: 'Beachballs, source-type lune plots and a compact results JSON are rendered and committed to a static store — no live model server in the request path.',
  },
  {
    n: '04',
    t: 'Explore',
    d: 'This viewer reads the precomputed month-long window. The time-slider is pure client-side filtering, so scrubbing is instant.',
  },
];
---

<BaseLayout
  title="Live Demo"
  description="Interactive preview of a real-time earthquake source-inference monitor for the Japan F-net region."
>
  <PageHeader
    eyebrow="Live demo · preview"
    title="Real-time earthquake source inference"
    lead="A continuously-updating monitor for the Japan (F-net) region. Each event is run through a neural posterior estimator; click a marker to compare the inferred moment tensor with the catalogue solutions. Drag the two-handle slider to select a date range over the catalogue."
  />

  <div class="container container--wide">
    <DemoViewer client:only="react">
      <div slot="fallback" class="demo-fallback">Loading interactive map…</div>
    </DemoViewer>
  </div>

  <section class="section how">
    <div class="container">
      <header class="section-head reveal">
        <p class="eyebrow">How it works</p>
        <h2>A decoupled, precompute-first pipeline</h2>
        <p class="lead">
          The interface above runs on the <strong>real Japan earthquake feed</strong>; the posterior
          clouds are sampled from the trained neural posterior estimator (NPE) for Japan F-net events,
          covering June 2026 onward. Freshness is two-tier: new events are discovered from
          <strong>USGS origins and inferred within about an hour</strong> of the earthquake (marked
          “F-net reference pending”), and when NIED publishes its F-net moment-tensor solution —
          typically days to a few weeks later — the event is re-inferred with the refined JMA location
          and the F-net reference attached for comparison. The pipeline itself processes each event in
          about two minutes, following a deliberately simple, low-cost architecture — described in full
          in the project's architecture document. Source-type labels are probabilistic: an event is
          only called non-double-couple when &gt;95% of its posterior mass falls outside a ±10°
          region around pure double-couple on the source-type lune — and for smaller earthquakes even
          these isotropic/CLVD indications are model-derived and cannot be checked against the F-net
          reference, which is constrained to be purely deviatoric.
        </p>
      </header>

      <ol class="pipeline">
        {
          pipeline.map((s, i) => (
            <li class="pipeline__step reveal" data-delay={`${i * 80}ms`}>
              <span class="pipeline__n">{s.n}</span>
              <h3 class="pipeline__t">{s.t}</h3>
              <p class="pipeline__d">{s.d}</p>
            </li>
          ))
        }
      </ol>

      <div class="how__note reveal">
        <p>
          <strong>Reused from my research library.</strong> The moment-tensor conventions, beachball rendering
          and source-type lune plots come straight from the seismology codebase that powers my published
          inversions — the web demo simply serves what the inference pipeline already produces.
        </p>
        <p class="muted">
          The scheduled worker, trained NPE and Japan-region Green's-function database are all live;
          if the feed is ever unreachable the viewer falls back to a bundled preview snapshot so the
          page still renders.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .demo-fallback {
    min-height: 540px;
    display: grid;
    place-items: center;
    margin-block: var(--space-5);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--bg-subtle);
    color: var(--ink-faint);
    font-family: var(--font-mono);
    font-size: var(--step--1);
  }

  .how {
    border-top: 1px solid var(--border);
    background: var(--bg-subtle);
  }
  .section-head {
    max-width: var(--measure);
    margin-bottom: var(--space-6);
  }
  .section-head h2 {
    margin-top: var(--space-2);
  }
  .section-head .lead {
    margin-top: var(--space-3);
  }

  .pipeline {
    list-style: none;
    padding: 0;
    display: grid;
    gap: var(--space-4);
    grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
  }
  .pipeline__step {
    padding: var(--space-5);
    background: var(--paper);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }
  .pipeline__n {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--accent);
  }
  .pipeline__t {
    font-size: var(--step-1);
    margin: var(--space-2) 0;
  }
  .pipeline__d {
    color: var(--ink-soft);
    font-size: var(--step-0);
  }

  .how__note {
    max-width: var(--measure);
    margin-top: var(--space-6);
    display: grid;
    gap: var(--space-3);
  }
</style>
