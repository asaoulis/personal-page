---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Icon from '../components/Icon.astro';
import HeroBackdrop from '../components/hero/HeroBackdrop';
import Imprint from '../components/imprint/Imprint';
import { SOCIALS } from '../config';
import { works, references } from '../data/works';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const refById = new Map(references.map((r) => [r.id, r]));
---

<BaseLayout>
  <!-- Hero: opens on the deep navy of the science, with the person front and centre.
       Behind it, the split backdrop: lensed galaxy-shear field | rupturing source
       solutions, meeting at a live seismogram. -->
  <section class="hero">
    <HeroBackdrop client:load />
    <div class="container hero__inner">
      <div class="hero__text">
        <p class="hero__eyebrow reveal">Machine learning for science</p>
        <h1 class="hero__name reveal" data-delay="60ms">Alex Saoulis</h1>
        <p class="hero__lead reveal" data-delay="120ms">
          I develop deep-learning methods for Bayesian inference and generative modelling, applied
          to problems in seismology, cosmology, and the climate sciences.
        </p>
        <div class="hero__cta reveal" data-delay="240ms">
          <a class="btn btn--primary" href="/demo/">
            Open the live earthquake monitor <Icon name="arrow" size={18} />
          </a>
          <a class="btn btn--onnavy" href="#work">Selected work</a>
        </div>
      </div>
      <div class="hero__portrait reveal" data-delay="120ms">
        <img
          src="/figures/headshot.jpeg"
          alt="Alex Saoulis"
          width="320"
          height="320"
          decoding="async"
        />
      </div>
    </div>
    <div class="hero__hints" aria-hidden="true">
      <p class="hero__hint reveal" data-delay="400ms">
        <b>move</b> — your cursor is a dark matter halo, shearing the image we receive of distant
        galaxies
      </p>
      <p class="hero__hint hero__hint--right reveal" data-delay="480ms">
        <b>click</b> — to produce a random earthquake, whose shaking is felt at the station on the
        seam
      </p>
    </div>
  </section>

  <!-- Short bio strip -->
  <section class="bio">
    <div class="container bio__inner reveal">
      <p>
        I am completing a PhD at <strong>UCL</strong> on machine-learning inference for seismology and
        cosmology, following an <strong>MPhys</strong> (first class) from <strong>Oxford</strong>.
        Alongside my research I have applied machine learning in industry: climate-risk modelling at
        Fathom, and two years of production engineering at a national particle accelerator facility.
      </p>
    </div>
  </section>

  <!-- The body of work, written like a paper's abstract with linked citations. -->
  <section id="work" class="section work">
    <div class="container">
      <header class="work__head reveal">
        <p class="eyebrow">Overview</p>
        <h2>Research</h2>
      </header>

      <div class="work__grid">
        <ol class="work__list">
          {
            works.map((w, i) => {
              const Tag = w.project ? 'a' : 'div';
              const attrs = w.project ? { href: w.project } : {};
              return (
                <li class="work__item reveal" data-delay={`${i * 60}ms`} data-domain={w.domain}>
                  <Tag class="work__go" {...attrs}>
                    <span class="work__text">{w.text}</span>
                    {w.cite.length > 0 && (
                      <span class="work__cites">
                        {w.cite.map((n) => {
                          const r = refById.get(n);
                          return (
                            <span class="cite" title={r?.label}>
                              [{n}]
                            </span>
                          );
                        })}
                      </span>
                    )}
                    {w.project && <Icon name="arrow" size={16} class="work__arrow" />}
                  </Tag>
                </li>
              );
            })
          }
        </ol>
        <div class="work__plate reveal" data-delay="120ms">
          <Imprint client:visible />
        </div>
      </div>

      <div class="dive reveal">
        <a class="dive__link" href="#gallery">See the projects <Icon name="arrow" size={18} /></a>
      </div>
    </div>
  </section>

  <!-- A quiet block-print divider before the gallery -->
  <div class="imprint-divider" aria-hidden="true">
    <Imprint variant="band" client:visible />
  </div>

  <!-- The pretty gallery -->
  <section id="gallery" class="section gallery">
    <div class="container">
      <ul class="gallery__grid">
        {
          projects.map((p, i) => (
            <li class="reveal" data-delay={`${(i % 3) * 80}ms`}>
              <ProjectCard project={p} />
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- References / selected papers -->
  <section class="section refs">
    <div class="container">
      <header class="refs__head reveal">
        <p class="eyebrow">References</p>
        <h2>Selected papers</h2>
      </header>
      <ol class="refs__list">
        {
          references.map((r) => (
            <li class="refs__item reveal">
              <span class="refs__num">[{r.id}]</span>
              <a href={r.href} class="refs__link">
                {r.label}
              </a>
              <span class="refs__venue">{r.venue}</span>
            </li>
          ))
        }
      </ol>
      <p class="refs__more reveal">
        Full list on
        {
          SOCIALS.filter((s) => s.icon === 'scholar' || s.icon === 'github').map((s, i) => (
            <>
              {i > 0 && ' and '}
              <a href={s.href}>{s.label}</a>
            </>
          ))
        }.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  /* ---- Hero (navy band) ---- */
  .hero {
    background:
      radial-gradient(
        80% 120% at 85% -10%,
        color-mix(in srgb, var(--live) 22%, transparent),
        transparent 55%
      ),
      radial-gradient(
        70% 110% at 5% 110%,
        color-mix(in srgb, var(--accent-on-navy) 20%, transparent),
        transparent 50%
      ),
      linear-gradient(160deg, var(--navy) 0%, var(--navy-2) 100%);
    color: var(--on-navy);
    padding-block: clamp(var(--space-8), 12vh, var(--space-10)) var(--space-9);
    position: relative;
    overflow: hidden;
  }
  .hero :global(.hero-backdrop) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    cursor: crosshair;
  }
  .hero__inner {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: var(--space-8);
    position: relative;
    z-index: 1;
    /* let the backdrop take the pointer everywhere except the CTAs */
    pointer-events: none;
  }
  .hero__cta :global(.btn) {
    pointer-events: auto;
  }
  /* panel captions along the bottom edge, one per world */
  .hero__hints {
    position: absolute;
    z-index: 1;
    left: 0;
    right: 0;
    bottom: 1.1rem;
    display: flex;
    justify-content: space-between;
    gap: var(--space-6);
    padding-inline: var(--space-6);
    pointer-events: none;
  }
  .hero__hint {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    line-height: 1.7;
    color: var(--on-navy-soft);
    opacity: 0.85;
    max-width: 44%;
  }
  .hero__hint b {
    color: var(--accent-on-navy);
    font-weight: 600;
  }
  .hero__hint--right {
    text-align: right;
  }
  @media (max-width: 720px) {
    .hero__hint--right {
      display: none; /* no seismic panel on small screens */
    }
    .hero__hint {
      max-width: 100%;
    }
  }
  .hero__eyebrow {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent-on-navy);
  }
  .hero__name {
    margin-top: var(--space-3);
    color: #fff;
    font-size: var(--step-5);
    text-shadow: 0 2px 24px rgba(10, 16, 36, 0.75);
  }
  .hero__lead {
    margin-top: var(--space-4);
    max-width: 34ch;
    font-family: var(--font-serif);
    font-size: var(--step-2);
    line-height: 1.32;
    color: var(--on-navy);
    text-shadow: 0 1px 16px rgba(10, 16, 36, 0.85);
  }
  .hero__cta {
    margin-top: var(--space-6);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }
  .hero__portrait img {
    width: clamp(9rem, 22vw, 15rem);
    height: clamp(9rem, 22vw, 15rem);
    object-fit: cover;
    border-radius: 50%;
    border: 3px solid color-mix(in srgb, var(--accent-on-navy) 40%, transparent);
    box-shadow:
      0 0 0 6px rgba(255, 255, 255, 0.04),
      var(--shadow-lg);
  }

  /* onnavy button variant, defined here where the navy context lives */
  .hero :global(.btn--onnavy) {
    background: rgba(255, 255, 255, 0.06);
    color: var(--on-navy);
    border: 1px solid rgba(255, 255, 255, 0.22);
  }
  .hero :global(.btn--onnavy:hover) {
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
    border-color: var(--accent-on-navy);
    transform: translateY(-1px);
  }

  /* ---- Bio strip ---- */
  .bio {
    background: var(--bg-subtle);
    border-bottom: 1px solid var(--border);
  }
  .bio__inner {
    padding-block: var(--space-5);
    max-width: 60ch;
    font-size: var(--step-1);
    color: var(--ink-soft);
  }
  .bio strong {
    color: var(--ink);
    font-weight: 600;
  }

  /* ---- Work list (abstract with citations) ---- */
  .work__head {
    max-width: var(--measure);
    margin-bottom: var(--space-6);
  }
  .work__head h2 {
    margin-top: var(--space-2);
  }
  .work__grid {
    display: grid;
    grid-template-columns: minmax(0, 62ch) 1fr;
    gap: var(--space-8);
    align-items: start;
  }
  .work__plate {
    position: sticky;
    top: calc(var(--header-h) + var(--space-6));
    justify-self: center;
    width: min(100%, 19rem);
  }
  .work :global(.imprint-plate) {
    margin: 0;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--paper);
    box-shadow: var(--shadow);
  }
  .work :global(.imprint-plate canvas) {
    display: block;
    width: 100%;
    height: 21rem;
    cursor: pointer;
  }
  .work :global(.imprint-plate figcaption) {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-faint);
    padding: 0.55rem 0.85rem;
    border-top: 1px solid var(--border);
  }
  @media (max-width: 1000px) {
    .work__grid {
      grid-template-columns: 1fr;
    }
    .work__plate {
      display: none;
    }
  }
  .work__list {
    list-style: none;
    padding: 0;
    max-width: 62ch;
    counter-reset: none;
  }
  .work__item {
    border-top: 1px solid var(--border);
  }
  .work__item:last-child {
    border-bottom: 1px solid var(--border);
  }
  .work__go {
    display: block;
    padding: var(--space-4) 2rem var(--space-4) 0;
    position: relative;
    color: var(--ink);
    font-size: var(--step-1);
    line-height: 1.5;
  }
  .work__go:hover {
    text-decoration: none;
    color: var(--ink);
  }
  .work__text {
    transition: color var(--dur) var(--ease);
  }
  a.work__go:hover .work__text {
    color: var(--accent-strong);
  }
  .work__cites {
    display: inline-flex;
    gap: 0.15rem;
    margin-left: 0.35rem;
    vertical-align: baseline;
  }
  .cite {
    font-family: var(--font-mono);
    font-size: 0.72em;
    color: var(--amber-strong);
    font-weight: 500;
  }
  .work__go :global(.work__arrow) {
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%) translateX(-4px);
    opacity: 0;
    color: var(--accent);
    transition:
      opacity var(--dur) var(--ease),
      transform var(--dur) var(--ease);
  }
  .work__go:hover :global(.work__arrow) {
    opacity: 1;
    transform: translateY(-50%) translateX(0);
  }

  .dive {
    margin-top: var(--space-6);
  }
  .dive__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: var(--step--1);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }
  .dive__link :global(svg) {
    transform: rotate(90deg);
    transition: transform var(--dur) var(--ease);
  }
  .dive__link:hover {
    color: var(--accent-strong);
    text-decoration: none;
  }
  .dive__link:hover :global(svg) {
    transform: rotate(90deg) translateX(3px);
  }

  /* ---- Imprint divider strip ---- */
  .imprint-divider :global(canvas.imprint-band) {
    display: block;
    width: 100%;
    height: 46px;
  }

  /* ---- Gallery ---- */
  .gallery {
    background: var(--bg-subtle);
    border-block: 1px solid var(--border);
  }
  .gallery__grid {
    list-style: none;
    padding: 0;
    display: grid;
    gap: var(--space-5);
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 20rem), 1fr));
  }

  /* ---- References ---- */
  .refs__head {
    margin-bottom: var(--space-5);
  }
  .refs__head h2 {
    margin-top: var(--space-2);
  }
  .refs__list {
    list-style: none;
    padding: 0;
    display: grid;
    gap: var(--space-3);
    max-width: var(--measure);
  }
  .refs__item {
    display: grid;
    grid-template-columns: 2rem 1fr;
    gap: 0.25rem var(--space-2);
    align-items: baseline;
  }
  .refs__num {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--amber-strong);
  }
  .refs__link {
    font-weight: 500;
  }
  .refs__venue {
    grid-column: 2;
    font-size: var(--step--1);
    color: var(--ink-faint);
  }
  .refs__more {
    margin-top: var(--space-5);
    color: var(--ink-soft);
    font-size: var(--step-0);
  }

  @media (max-width: 720px) {
    .hero__inner {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
    .hero__portrait {
      order: -1;
    }
  }
</style>
