---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import ProjectCard from '../../components/ProjectCard.astro';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Projects"
  description="Research projects and deployments — simulation-based inference across seismology, cosmology and climate."
>
  <PageHeader
    eyebrow="Projects"
    title="Things I've built & studied"
    lead="A live deployment of my seismology research sits alongside parallel threads in cosmology and diffusion-based climate modelling. More will be added here over time."
  />

  <section class="section">
    <div class="container">
      <ul class="cards-grid">
        {
          projects.map((p, i) => (
            <li class="reveal" data-delay={`${i * 90}ms`}>
              <ProjectCard project={p} />
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .cards-grid {
    list-style: none;
    padding: 0;
    display: grid;
    gap: var(--space-5);
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 20rem), 1fr));
  }
</style>
