---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import Icon from '../components/Icon.astro';
import { SITE } from '../config';

const experience = [
  {
    when: '2024–2026',
    what: 'Machine Learning Consultant',
    where: 'Fathom',
    note: 'Sole machine-learning specialist on a diffusion-based precipitation downscaling system for flood risk. Developed the full geospatial pipeline (ERA5, MSWEP) and delivered at continental-US scale within a 6-month timeline, then consulted part-time. Paper under review at JGR.',
  },
  {
    when: '2020–2022',
    what: 'Software Engineer & ML Graduate',
    where: 'ISIS Neutron and Muon Source, STFC',
    note: 'Two years of production ML on a live accelerator control system: anomaly detection and forecasting on continuous signals, plus a live Bayesian-optimisation system for beam tuning. Python and C++, Docker, CI/CD.',
  },
];

const education = [
  {
    when: '2022–2026',
    what: 'PhD, Data Intensive Science',
    where: 'University College London',
    note: 'Machine-learning Bayesian inference across seismology and cosmology. Physics & Astronomy, Data Intensive Science CDT. Submission expected late 2026.',
  },
  {
    when: '2016–2020',
    what: 'MPhys Physics, First-Class Honours',
    where: 'University of Oxford',
    note: 'St Peter’s College. Dissertation on numerical methods for squeezed, driven quantum states.',
  },
];

const publications = [
  {
    cite: 'Full-waveform earthquake source inversion using simulation-based inference. Geophysical Journal International 241(3), 2025.',
    href: 'https://arxiv.org/abs/2410.23238',
  },
  {
    cite: 'Transfer learning for multifidelity simulation-based inference in cosmology. MNRAS 542(4), 2025.',
    href: 'https://arxiv.org/abs/2505.21215',
  },
  {
    cite: 'Field-level weak-lensing cosmology with <100 simulations using multifidelity SBI. Preprint, 2026.',
    href: 'https://arxiv.org/abs/2606.23346',
  },
  {
    cite: 'Improving moment tensor solutions under Earth-structure uncertainty with SBI. Preprint, 2026.',
    href: 'https://arxiv.org/abs/2603.18925',
  },
  {
    cite: 'Semantic segmentation for feature detection in ocean-bottom seismometer data. Seismica 5(1), 2026.',
    href: 'https://doi.org/10.26443/seismica.v5i1.1821',
  },
  {
    cite: 'Diffusion models for climate data surpass alternative statistical downscaling techniques. Preprint, 2025 (JGR under review).',
    href: 'https://essopenarchive.org/doi/full/10.22541/essoar.173869444.40681416/v1',
  },
];

const talks = [
  { when: '2025', what: 'Invited oral: AGU 2025; ENIGMA Collaboration 2025' },
  { when: '2023/24', what: 'EGU General Assembly: SBI source inversion; diffusion downscaling' },
];

const skills = [
  'Python',
  'PyTorch',
  'Simulation-based inference',
  'Bayesian inference',
  'Normalising flows',
  'Diffusion & generative models',
  'CNNs / Vision Transformers',
  'Semantic segmentation',
  'Time-series analysis',
  'Slurm / MPI / HPC',
  'Docker / CI/CD',
  'ERA5 / MSWEP geospatial data',
];
---

<BaseLayout title="CV" description={`Curriculum vitae of ${SITE.title}.`}>
  <PageHeader
    eyebrow="Curriculum vitae"
    title="CV"
    lead="Machine-learning researcher completing a PhD in probabilistic and generative deep learning, with two years of production engineering experience."
  />

  <section class="section">
    <div class="container cv">
      <div class="cv__actions reveal">
        <a class="btn btn--primary" href="/cv.pdf" download>
          Download PDF <Icon name="arrow" size={18} />
        </a>
      </div>

      <div class="cv__col">
        <section class="cv__section reveal">
          <h2>Skills</h2>
          <ul class="skills">
            {skills.map((s) => <li>{s}</li>)}
          </ul>
        </section>

        <section class="cv__section reveal">
          <h2>Education</h2>
          <ul class="timeline">
            {
              education.map((e) => (
                <li>
                  <span class="timeline__when">{e.when}</span>
                  <div>
                    <p class="timeline__what">{e.what}</p>
                    <p class="timeline__where">{e.where}</p>
                    <p class="timeline__note muted">{e.note}</p>
                  </div>
                </li>
              ))
            }
          </ul>
        </section>

        <section class="cv__section reveal">
          <h2>Experience</h2>
          <ul class="timeline">
            {
              experience.map((e) => (
                <li>
                  <span class="timeline__when">{e.when}</span>
                  <div>
                    <p class="timeline__what">{e.what}</p>
                    <p class="timeline__where">{e.where}</p>
                    <p class="timeline__note muted">{e.note}</p>
                  </div>
                </li>
              ))
            }
          </ul>
        </section>

        <section class="cv__section reveal">
          <h2>Selected publications</h2>
          <p class="cv__pubnote muted">
            Six first-author papers, two in Q1 journals. Full list on Google Scholar.
          </p>
          <ul class="pub-list">
            {
              publications.map((p) => (
                <li>
                  <a href={p.href}>{p.cite}</a>
                </li>
              ))
            }
          </ul>
        </section>

        <section class="cv__section reveal">
          <h2>Talks</h2>
          <ul class="timeline">
            {
              talks.map((t) => (
                <li>
                  <span class="timeline__when">{t.when}</span>
                  <div>
                    <p class="timeline__what">{t.what}</p>
                  </div>
                </li>
              ))
            }
          </ul>
        </section>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .cv {
    display: grid;
    gap: var(--space-7);
  }
  .cv__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3) var(--space-4);
  }
  .cv__col {
    display: grid;
    gap: var(--space-7);
    max-width: 48rem;
  }
  .cv__section h2 {
    font-size: var(--step-2);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--border);
    margin-bottom: var(--space-4);
  }
  .cv__pubnote {
    font-size: var(--step--1);
    margin-bottom: var(--space-4);
  }

  .timeline {
    list-style: none;
    padding: 0;
    display: grid;
    gap: var(--space-4);
  }
  .timeline li {
    display: grid;
    grid-template-columns: 8.5rem 1fr;
    gap: var(--space-4);
  }
  .timeline__when {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--accent);
    padding-top: 0.15rem;
  }
  .timeline__what {
    font-weight: 600;
  }
  .timeline__where {
    color: var(--ink-soft);
  }
  .timeline__note {
    font-size: var(--step--1);
    margin-top: 0.15rem;
  }

  .pub-list {
    list-style: none;
    padding: 0;
    display: grid;
    gap: var(--space-3);
  }
  .pub-list a {
    color: var(--ink);
  }
  .pub-list a:hover {
    color: var(--accent-strong);
  }

  .skills {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  .skills li {
    font-size: var(--step--1);
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.25rem 0.7rem;
  }

  @media (max-width: 620px) {
    .timeline li {
      grid-template-columns: 1fr;
      gap: var(--space-1);
    }
  }
</style>
