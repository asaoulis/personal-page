# ─────────────────────────────────────────────────────────────────────────────
# Secrets for the FUTURE live-demo inference worker.
#
# The static Astro frontend needs NO secrets to build or deploy — these are used
# only by the scheduled inference worker described in docs/ARCHITECTURE.md.
# Copy to `.env` for local worker runs, or store as GitHub Actions repository
# secrets for the scheduled job. NEVER commit a real `.env` (it is gitignored).
# ─────────────────────────────────────────────────────────────────────────────

# NIED / F-net (Japan) data portal credentials — re-registered periodically.
FNET_USERNAME=
FNET_PASSWORD=

# Optional: catalogue / waveform FDSN endpoint (defaults documented in the worker).
# CATALOGUE_FDSN_URL=https://service.iris.edu

# Optional basemap provider key — ONLY if not using the keyless OpenFreeMap tiles.
# MAPTILER_KEY=
